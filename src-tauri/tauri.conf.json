{
  "package": {
    "productName": "HackT",
    "version": "1.0.0"
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "app": { "all": true },
      "dialog": { "all": true },
      "fs": {
        "all": true,
        "scope": ["$HOME/**/*", "$APPDATA/HackT/**/*"]
      },
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "targets": ["nsis"],
      "identifier": "com.hackt.runtime",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [
        "resources/**/*"
      ],
      "copyright": "© 2026 HackT Systems",
      "category": "DeveloperTool",
      "shortDescription": "Sovereign AI Security Agent",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "http://timestamp.digicert.com",
        "nsis": {
          "installMode": "perMachine",
          "displayLanguageSelector": false,
          "installerIcon": "icons/installer.ico",
          "headerImage": "../installer-assets/header.bmp",
          "sidebarImage": "../installer-assets/sidebar.bmp",
          "license": "../installer-assets/license.txt",
          "template": "../installer-assets/nsis/custom_template.nsi"
        }
      }
    },
    "systemTray": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "label": "main",
        "url": "/",
        "title": "HackT Sovereign Agent",
        "width": 1200,
        "height": 800,
        "visible": false,
        "center": true,
        "decorations": true
      },
      {
        "label": "splashscreen",
        "url": "/splash.html",
        "width": 400,
        "height": 400,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true
      },
      {
        "label": "bubble",
        "url": "/#/bubble",
        "width": 180,
        "height": 180,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false,
        "center": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:8000 http://127.0.0.1:8000 ws://localhost:8000 ws://127.0.0.1:8000 'unsafe-inline' 'unsafe-eval'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' http://localhost:8000 http://127.0.0.1:8000 ws://localhost:8000 ws://127.0.0.1:8000;"
    }
  }
}
{
  "package": {
    "productName": "HackT",
    "version": "1.0.0"
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "targets": ["nsis"],
      "identifier": "com.hackt.runtime",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "externalBin": [
        "binaries/backend_service"
      ],
      "windows": {
        "nsis": {
          "installMode": "perMachine",
          "displayLanguageSelector": false
        }
      }
    },
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true,
        "sidecar": true,
        "scope": [
          {
            "name": "binaries/backend_service",
            "sidecar": true
          }
        ]
      },
      "window": {
        "all": false,
        "show": true,
        "hide": true,
        "setAlwaysOnTop": true
      },
      "protocol": {
        "asset": true
      }
    },
    "systemTray": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "label": "main",
        "title": "HackT Sovereign Agent",
        "width": 1200,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      },
      {
        "label": "bubble",
        "url": "/#/bubble",
        "width": 180,
        "height": 180,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
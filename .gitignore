# =============================================================================
# HACKT RUNTIME – MASTER GITIGNORE (Production)
# Architecture: React (Vite) + Rust (Tauri) + Python (FastAPI)
# =============================================================================

# -----------------------------------------------------------------------------
# 1. SENSITIVE DATA & SECRETS (CRITICAL)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.cert
**/secrets.json
**/supabase.json
**/config.json
# -----------------------------------------------------------------------------
# 2. AI MODELS & KNOWLEDGE VAULT (LOCAL SOVEREIGNTY)
# -----------------------------------------------------------------------------
# Preserve the nested models/ folder structure but ignore the gigabytes of weights
backend_service/models/*
!backend_service/models/.gitkeep

# Knowledge Vault & Database files
backend_service/data/
*.lance
*.lance/
*.graph
*.graph/
*.kuzu
*.wal
*.log.v*
**/__index__/**
_temp_index/
index.zip
backend_service/models/bm25_index.pkl
backend_service/models/file_summaries.json

# -----------------------------------------------------------------------------
# 3. FRONTEND (React + Vite + TypeScript)
# -----------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
build/
.vite/
.eslintcache

# Logs & Lockfiles (Remove lockfiles from here if you prefer reproducible CI/CD builds)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# -----------------------------------------------------------------------------
# 4. RUST + TAURI (OS Layer)
# -----------------------------------------------------------------------------
# Build artifacts
src-tauri/target/
**/target/
src-tauri/binaries/

# Bundled Python folder (Derived artifact; prevents adding 300MB+ per commit)
src-tauri/resources/hackt_sovereign_core/

# Rust internals
**/*.rs.bk
src-tauri/app.manifest.bak
Cargo.lock # Remove if you want strict dependency locking in Git

# -----------------------------------------------------------------------------
# 5. PYTHON BACKEND (AI Core)
# -----------------------------------------------------------------------------
# PyInstaller build artifacts
backend_service/build/
backend_service/dist/
backend_service/*.spec

# Cache & Compiled Files
__pycache__/
**/*.py[cod]
**/*.pyo
**/*.pyd
**/*.so
**/*.dll

# Virtual Environments
venv/
.venv/
env/
.env/
ENV/

# Python testing & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# -----------------------------------------------------------------------------
# 6. LOGS & TELEMETRY
# -----------------------------------------------------------------------------
logs/
*.log
runtime_*.log
audit trail/

# Local SQLite databases (Prevents overwriting dev states)
**/*.db
**/*.db-journal
**/*.sqlite3

# -----------------------------------------------------------------------------
# 7. OS & IDE / EDITOR
# -----------------------------------------------------------------------------
# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
System Volume Information/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.fuse_hidden*
.Trash-*

# IDEs
.vscode/
.idea/
*.swp
*.swo
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# 8. FINAL INSTALLERS & TEMPORARY FILES
# -----------------------------------------------------------------------------
# Final installers should not be committed (Use GitHub Releases instead)
*.exe
*.msi
*.deb
*.rpm
*.dmg
*.app
*.appimage
*.AppImage
bundles/
installers/

# Temporary Files
tmp/
temp/
*.tmp
*.temp
.cache/